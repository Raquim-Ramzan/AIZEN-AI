# ==============================================================
# AIZEN — Environment Configuration (2026 Production)
# ==============================================================
# Copy this to `backend/.env`
# ==============================================================

# --- API Keys --------------------------------------------------
# Required for Cloud-Native features
GEMINI_API_KEY=""
GROQ_API_KEY=""
PERPLEXITY_API_KEY=""

# --- Supabase (Primary Persistence) ----------------------------
# Found in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"

# --- AIZEN System Auth -----------------------------------------
# Optional: Set a secret key for strict API access
AIZEN_API_KEY=""

# --- 2026 Model Routing ----------------------------------------
MODEL_CODING="gemini-3.1-pro-preview"
MODEL_CHAT="gemini-3-flash-preview"
MODEL_REASONING="gemini-3.1-pro-preview"
MODEL_SEARCH="sonar-pro"
MODEL_EMBEDDING="BAAI/bge-small-en-v1.5"

# --- Local Fallback (Ollama) -----------------------------------
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b-instruct-q6_K"

# --- Server Configuration --------------------------------------
PORT=8001
HOST="0.0.0.0"
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"
ENV="development" # Set to 'production' for strict RLS/Auth
