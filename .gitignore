# ==============================================================
# AIZEN — Project .gitignore
# ==============================================================

# Environment & secrets (CRITICAL — never commit)
.env
.env.*
!.env.example
*token.json*
*credentials.json*

# IDE and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
venv/
.venv/
*.egg-info/
*.egg

# Production builds
dist/
build/
*.tsbuildinfo

# Backend data (user data — never commit)
backend/data/
backend/pip_install_log.txt

# Logs and debug artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dump.rdb

# Lint / test artifacts
eslint_report.json
lint_results.json
lint_output*.txt
compact_lint.txt
coverage/

# System files
.DS_Store
Thumbs.db
*.pem

# Binary artifacts — do not track executables in source
*.exe
*.dll
*.so
*.dylib

# Archive files
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb

# Deployment
.vercel
.cache/

# Agent / AI session files
.agent/

# Voice preview assets
voice_previews/

# Misc
chainlit.md
.chainlit
.ipynb_checkpoints/
android-sdk/
