# ==============================================================
# AIZEN Backend — Environment Configuration
# ==============================================================
# Copy this file to `.env` and fill in your API keys.
#   cp .env.example .env
#
# NEVER commit `.env` to version control.
# ==============================================================

# --- API Keys (REQUIRED: at least one provider) ----------------
PERPLEXITY_API_KEY=""
GEMINI_API_KEY=""
GOOGLE_API_KEY=""
GROQ_API_KEY=""

# --- AIZEN API Authentication -----------------------------------
# (Optional if using Supabase Auth, but kept for system operations fallback)
# Clients must send this as `Authorization: Bearer <key>` header.
# Generate a strong random value:  python -c "import secrets; print(secrets.token_urlsafe(48))"
AIZEN_API_KEY=""

# --- Supabase Database & Auth ----------------------------------
SUPABASE_URL=""
SUPABASE_KEY=""

# --- Model Preferences for Different Task Types ----------------
MODEL_CODING="gemini-3-flash-preview"
MODEL_CHAT="gemini-3-flash-preview"
MODEL_REASONING="gemini-3-flash-preview"
MODEL_SEARCH="sonar-pro"
MODEL_RESEARCH="sonar-deep-research"
MODEL_IMAGE="imagen-4-ultra"
MODEL_EMBEDDING="text-embedding-004"
MODEL_FAST_STREAMING="groq-compound"

# --- Ollama Configuration (optional, local fallback) -----------
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b-instruct-q6_K"

# --- Memory / Storage ------------------------------------------
MONGO_URL="mongodb://localhost:27017"
DB_NAME="ai_assistant"
CHROMA_PERSIST_DIR="./data/vector_store"
SQLITE_DB="./data/conversations.db"
CORE_MEMORY_FILE="./data/core_memory.json"

# --- Server Settings -------------------------------------------
HOST="0.0.0.0"
PORT="8001"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- Application Settings --------------------------------------
ENVIRONMENT="development"
DEBUG="false"
LOG_LEVEL="INFO"
